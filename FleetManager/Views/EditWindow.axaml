<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FleetManager.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FleetManager.Views.EditWindow"
        x:DataType="vm:EditWindowViewModel"
        Title="EditWindow">
    
        
        <StackPanel Margin="20" Spacing="10">
                <TextBlock Text="Edytuj bohatera" FontSize="18" FontWeight="Bold"/>

                <TextBox Text="{Binding Name}" Watermark="Nazwa Pojazdu"/>
                <TextBox Text="{Binding LicenseNumber}" Watermark="Numer Rejestracyjny"/>
                <TextBox Text="{Binding FuelPercentage}" Watermark="Zawartość zbiornika na paliwo"/>
                <TextBox Text="{Binding Status}" Watermark="Status pojazdu"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Zapisz" Command="{Binding SaveCommand}"/>
                        <Button Content="Anuluj" Command="{Binding CancelCommand}"/>
                </StackPanel>
        </StackPanel>
</Window>
